pipeline {

    agent any

    tools {
        maven 'maven3'
        jdk 'jdk21'
    }

    stages {

        stage('Checkout') {

            steps {

                git branch: 'main',
                url: 'https://github.com/parimallpradhan/enterprise-devsecops-platform.git'
            }
        }

        stage('Compile') {

            steps {

                dir('devsecops-app') {

                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {

            steps {

                dir('devsecops-app') {

                    sh 'mvn test'
                }
            }

            post {

                always {

                   junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml'
                }

                success {

                    echo 'All unit tests passed successfully'
                }

                failure {

                    echo 'Unit tests failed. Stopping pipeline.'
                }
            }
        }

stage('SonarQube Analysis') {

    steps {

        dir('devsecops-app') {

            withSonarQubeEnv('sonarqube') {

                sh '''
                mvn sonar:sonar \
                -Dsonar.projectKey=devsecops-app \
                -Dsonar.projectName=devsecops-app
                '''
            }
        }
    }
}
stage('Quality Gate') {

    steps {

        timeout(time: 5, unit: 'MINUTES') {

            waitForQualityGate abortPipeline: true
        }
    }
}
        stage('Package') {

            steps {

                dir('devsecops-app') {

                    sh 'mvn package'
                }
            }
        }

        stage('Application Smoke Test') {

            steps {

                dir('devsecops-app') {

                    sh '''
                    nohup java -jar target/devsecops-app-1.0.jar > app.log 2>&1 &
                    '''

                    sleep 20

                    sh 'curl -f http://localhost:8081/health'
                }
            }
        }
    }

    post {

        always {

            sh '''
            pkill -f devsecops-app || true
            '''

            archiveArtifacts artifacts: '**/target/*.jar',
            allowEmptyArchive: true
        }
    }
}

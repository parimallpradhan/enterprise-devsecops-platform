pipeline {

    agent any

    tools {
        maven 'maven3'
        jdk 'jdk21'
    }

    stages {

        stage('Checkout') {

            steps {

                git branch: 'main',
                url: 'https://github.com/parimallpradhan/enterprise-devsecops-platform.git'
            }
        }

        stage('Compile') {

            steps {

                dir('devsecops-app') {

                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {

            steps {

                dir('devsecops-app') {

                    sh 'mvn test'
                }
            }

            post {

                always {

                    junit allowEmptyResults: true,
                    testResults: '**/target/surefire-reports/*.xml'
                }

                success {

                    echo 'All unit tests passed successfully'
                }

                failure {

                    echo 'Unit tests failed. Stopping pipeline.'
                }
            }
        }

        stage('SonarQube Analysis') {

            steps {

                dir('devsecops-app') {

                    withSonarQubeEnv('sonarqube') {

                        sh '''
                        mvn sonar:sonar \
                        -Dsonar.projectKey=devsecops-app \
                        -Dsonar.projectName=devsecops-app
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {

            steps {

                timeout(time: 5, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Trivy Filesystem Scan') {

            steps {

                dir('devsecops-app') {

                    sh '''
                    mkdir -p trivy-reports

                    trivy fs . \
                    --severity CRITICAL,HIGH \
                    --exit-code 0 \
                    --format json \
                    --output trivy-reports/trivy-report.json

                    trivy fs . \
                    --severity CRITICAL,HIGH \
                    --exit-code 0 \
                    --format table \
                    > trivy-reports/trivy-report.txt
                    '''
                }
            }

            post {

                always {

                    archiveArtifacts artifacts: 'devsecops-app/trivy-reports/*',
                    allowEmptyArchive: true
                }
            }
        }

        stage('Package') {

            steps {

                dir('devsecops-app') {

                    sh 'mvn package'
                }
            }
        }

        stage('Publish Artifact to Nexus') {

            steps {

                dir('devsecops-app') {

                    sh 'mvn deploy'
                }
            }
        }

        stage('Application Smoke Test') {

            steps {

                dir('devsecops-app') {

                    sh '''
                    echo "===== TARGET DIRECTORY ====="

                    ls -lrth target/

                    echo "===== STARTING APPLICATION ====="

                    nohup java -jar target/*.jar > app.log 2>&1 &

                    sleep 30

                    echo "===== APPLICATION LOGS ====="

                    cat app.log

                    echo "===== RUNNING PORTS ====="

                    netstat -tulpn | grep 8082 || true

                    echo "===== HEALTH CHECK ====="

                    curl -v http://localhost:8082/actuator/health
                    '''
                }
            }
        }

        stage('Docker Build') {

            steps {

                dir('devsecops-app') {

                    sh '''
                    export DOCKER_BUILDKIT=1

                    docker build \
                    -t parimal1984/devsecops-app:${BUILD_NUMBER} .
                    '''
                }
            }
        }

        stage('Trivy Docker Image Scan') {

            steps {

                dir('devsecops-app') {

                    sh '''
                    mkdir -p trivy-image-reports

                    trivy image \
                    --severity CRITICAL,HIGH \
                    --exit-code 0 \
                    --format json \
                    --output trivy-image-reports/docker-image-report.json \
                    parimal1984/devsecops-app:${BUILD_NUMBER}

                    trivy image \
                    --severity CRITICAL,HIGH \
                    --exit-code 0 \
                    --format table \
                    parimal1984/devsecops-app:${BUILD_NUMBER} \
                    > trivy-image-reports/docker-image-report.txt
                    '''
                }
            }

            post {

                always {

                    archiveArtifacts artifacts: 'devsecops-app/trivy-image-reports/*',
                    allowEmptyArchive: true
                }
            }
        }

stage('Docker Push to DockerHub') {

    steps {

        script {

            withCredentials([usernamePassword(
                credentialsId: 'dockerhub-creds',
                usernameVariable: 'DOCKER_USER',
                passwordVariable: 'DOCKER_PASS'
            )]) {

                sh '''
                echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin

                docker push $DOCKER_USER/devsecops-app:${BUILD_NUMBER}
                '''
            }
        }
    }
}

    }

    post {

        always {

            sh '''
            pkill -f devsecops-app || true
            '''

            archiveArtifacts artifacts: '**/target/*.jar',
            allowEmptyArchive: true
        }
    }
}


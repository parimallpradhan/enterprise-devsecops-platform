pipeline {

    agent any

    tools {
        maven 'maven3'
        jdk 'jdk21'
    }

    stages {

        stage('Checkout') {

            steps {

                git branch: 'main',
                url: 'https://github.com/parimallpradhan/enterprise-devsecops-platform.git'
            }
        }

        stage('Compile') {

            steps {

                dir('devsecops-app') {

                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {

            steps {

                dir('devsecops-app') {

                    sh 'mvn test'
                }
            }
        }

        stage('Package') {

            steps {

                dir('devsecops-app') {

                    sh 'mvn package'
                }
            }
        }

        stage('Application Smoke Test') {

            steps {

                dir('devsecops-app') {

                    sh '''
                    nohup java -jar target/devsecops-app-1.0.jar > app.log 2>&1 &
                    '''

                    sleep 20

                    sh 'curl -f http://localhost:8081/health'
                }
            }
        }
    }

    post {

        always {

            sh '''
            pkill -f devsecops-app || true
            '''

            archiveArtifacts artifacts: '**/target/*.jar',
            allowEmptyArchive: true
        }
    }
}

